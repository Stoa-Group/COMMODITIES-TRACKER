# FRED API - get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# stoagroupDB API (e.g. https://stoagroupdb-ddre.onrender.com)
STOAGROUP_API_URL=https://stoagroupdb-ddre.onrender.com

# Ingest key - must match COMMODITIES_INGEST_KEY on the API server
COMMODITIES_INGEST_KEY=your_ingest_key
